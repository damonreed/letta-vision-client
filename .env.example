LETTA_BASE_URL=http://localhost:8283
LETTA_SERVER_PASSWORD=

# How long the bridge waits for Letta to finish a chat (seconds). Match LETTA_LLM_STREAM_TIMEOUT_SECONDS in deploy.
LETTA_CLIENT_READ_TIMEOUT_SECONDS=600

# Optional: max upload size in bytes (0 = unlimited). Set on internet-facing hosts to limit memory DoS.
VISION_MAX_UPLOAD_BYTES=0

VISION_MAX_REQUEST_BYTES=26214400
